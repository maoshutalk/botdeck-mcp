# BotDeck MCP Server Configuration

# BotDeck API URL (required)
# Example: http://your-api-host:port/api/v1
BOTDECK_API_URL=

# BotDeck API Token (Bearer token, required)
BOTDECK_API_TOKEN=

# MCP Server Port (optional, defaults to 3000)
MCP_SERVER_PORT=3000

# Test Configuration (for development/testing only)
TEST_AGENT_NAME=
TEST_TASK_ID=
